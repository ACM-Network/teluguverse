    "slug": "my-wife-has-no-emotion-2024",
    "type": "ANIME",
    "status": "COMPLETED",
    "poster": "https://image.tmdb.org/t/p/w500/ttaknfJP0qjg7kMKwH0w29fcE6d.jpg",
