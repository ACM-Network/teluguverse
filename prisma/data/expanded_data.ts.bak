  {
    "slug": "johnny-bravo-1997",
    "type": "CARTOON",
    "status": "COMPLETED",
    "poster": "https://image.tmdb.org/t/p/w500/obbdeoOk8XSXzJrWGiBbaeMMSMl.jpg",
