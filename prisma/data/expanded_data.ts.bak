  {
    "slug": "fullmetal-alchemist-brotherhood-2009",
    "type": "ANIME",
    "status": "COMPLETED",
    "poster": "https://image.tmdb.org/t/p/w500/5ZFUEOULaVml7pQuXxhpR2SmVUw.jpg",
