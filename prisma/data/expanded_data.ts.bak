    "slug": "we-bare-bears-2015",
    "type": "CARTOON",
    "status": "COMPLETED",
    "poster": "https://image.tmdb.org/t/p/w500/3xWzlLZ0kAD6SkVZTekFM9lxZyP.jpg",
