  {
    "slug": "my-dress-up-darling-2022",
    "type": "ANIME",
    "status": "COMPLETED",
    "poster": "https://image.tmdb.org/t/p/w500/A6mxBwvvv63JXZm3xXKv4SugE0L.jpg",
