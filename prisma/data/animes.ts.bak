  {
    "slug": "akebi-chan-100-man-bu-2022",
    "type": "ANIME",
    "status": "COMPLETED",
    "poster": "https://image.tmdb.org/t/p/w500/kGMOxl3o9QNeRzAvmeDJaaxLrtV.jpg",
