  {
    "slug": "dark-moon-the-blood-altar-2026",
    "type": "ANIME",
    "status": "COMPLETED",
    "poster": "https://image.tmdb.org/t/p/w500/68HcRvCpiajsPhKn1MnV4hqeCAN.jpg",
